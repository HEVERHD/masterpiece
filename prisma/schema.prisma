generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  images      Image[]
  sizes       ProductSize[]
  color       String?
  isVisible   Boolean       @default(true)
  lowStockAt  Int           @default(3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  combos      ProductCombo[] @relation("Combos")
  comboOf     ProductCombo[] @relation("CombosOf")

  @@index([categoryId])
  @@index([isVisible])
}

model ProductCombo {
  productId String
  relatedId String
  product   Product @relation("Combos",   fields: [productId], references: [id], onDelete: Cascade)
  related   Product @relation("CombosOf", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([productId, relatedId])
  @@index([productId])
}

model Image {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@index([productId])
}

model ProductSize {
  id        String  @id @default(cuid())
  size      String
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  ENVIADO
  CANCELADO
}

model Order {
  id            String      @id @default(cuid())
  productId     String?
  productName   String
  size          String?
  price         String
  customerName  String
  customerPhone String
  deliveryType  String
  address       String?
  city          String?
  carrier       String?
  message       String?
  items         Json?
  adminNote     String?
  status        OrderStatus @default(PENDIENTE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model PaymentMethod {
  id       String  @id @default(cuid())
  title    String  // e.g. "🏦 Bancolombia"
  subtitle String? // e.g. "Cuenta Ahorro · Darío Marín"
  value    String? // copyable data, e.g. "91289105137"
  appLink  String? // deep link to open the app, e.g. "bancolombia://"
  order    Int     @default(0)
  active   Boolean @default(true)
}

model StockAlert {
  id          String   @id @default(cuid())
  productId   String
  productName String
  size        String?
  phone       String
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId])
}
