# ─────────────────────────────────────────────
# Masterpiece CTG — Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ─────────────────────────────────────────────

# Base URL de la aplicación (en Vercel se setea automáticamente)
NEXT_PUBLIC_URL=https://masterpiecectg.vercel.app

# ─── Neon PostgreSQL ──────────────────────────
# Consigue estas URLs en: https://console.neon.tech
# Proyecto → Connection string → "Pooled" (para DATABASE_URL)
# y "Direct" (para DIRECT_URL)
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/masterpiecectg?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/masterpiecectg?sslmode=require

# ─── NextAuth ────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO_DE_32_CHARS

# ─── Admin ───────────────────────────────────
# Contraseña de acceso al panel admin
ADMIN_PASSWORD=TuContrasenaSegura123!

# ─── Vercel Blob ─────────────────────────────
# Se configura automáticamente al conectar Vercel Blob Storage
# en el dashboard de Vercel → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxx
