generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String         @id @default(cuid())
  name        String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  categoryId  String
  isVisible   Boolean        @default(true)
  lowStockAt  Int            @default(3)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  color       String?
  images      Image[]
  category    Category       @relation(fields: [categoryId], references: [id])
  combos      ProductCombo[] @relation("Combos")
  comboOf     ProductCombo[] @relation("CombosOf")
  sizes       ProductSize[]

  @@index([categoryId])
  @@index([isVisible])
}

model ProductCombo {
  productId String
  relatedId String
  product   Product @relation("Combos", fields: [productId], references: [id], onDelete: Cascade)
  related   Product @relation("CombosOf", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([productId, relatedId])
  @@index([productId])
}

model Image {
  id        String  @id @default(cuid())
  url       String
  productId String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSize {
  id        String  @id @default(cuid())
  size      String
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  productId     String?
  productName   String
  size          String?
  price         String
  customerName  String
  customerPhone String
  deliveryType  String
  address       String?
  city          String?
  carrier       String?
  message       String?
  status        OrderStatus @default(PENDIENTE)
  source        String      @default("web")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         Json?
  adminNote     String?

  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model PaymentMethod {
  id       String  @id @default(cuid())
  title    String
  subtitle String?
  value    String?
  order    Int     @default(0)
  active   Boolean @default(true)
  appLink  String?
}

model StockAlert {
  id          String   @id @default(cuid())
  productId   String
  productName String
  size        String?
  phone       String
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  ENVIADO
  CANCELADO
}
